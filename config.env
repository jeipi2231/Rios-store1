# Configuración del Sistema de Gestión
# Edita este archivo si necesitas cambiar la configuración de la base de datos
# Abre este archivo con el Bloc de notas (Notepad)

# URL base del sistema (cambia si instalas en subdirectorio, ej: /sistema/app/)
BASE_URL=/

# Servidor de MySQL (normalmente 'localhost' para XAMPP)
DB_HOST=localhost

# Nombre de la base de datos
DB_NAME=despensa_db

# Usuario de MySQL (normalmente 'root' para XAMPP)
DB_USER=root

# Contraseña de MySQL (deja vacío si no tienes contraseña)
DB_PASS=

# ===========================================
# INSTRUCCIONES:
# 1. Si tu MySQL tiene contraseña, escribe aquí arriba
# 2. Si usas un servidor diferente, cambia DB_HOST
# 3. Si creaste la BD con otro nombre, cambia DB_NAME
# 4. Guarda este archivo y reinicia el navegador
# ===========================================